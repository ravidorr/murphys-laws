{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "noEmit": true,
    "allowJs": false,
    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": [
    "src/**/*.ts",
    "../backend/src/services/**/*.ts",
    "../backend/src/utils/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}

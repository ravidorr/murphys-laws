  "description": "MCP server for Murphy's Laws - exposes 1500+ laws to AI agents via Model Context Protocol",
  "type": "module",
  "main": "src/index.ts",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "tsx src/index.ts",

{
  "name": "murphys-laws-mcp",
  "version": "1.0.0",
  "description": "MCP server for Murphy's Laws - exposes 1500+ laws to AI agents via Model Context Protocol",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "murphys-laws-mcp": "bin/cli.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "inspect": "npx @modelcontextprotocol/inspector tsx src/index.ts"
  },
  "keywords": [
    "murphys-law",
    "mcp",
    "model-context-protocol",
    "ai-agent"
  ],
  "mcpName": "murphys-laws.com/murphys-laws",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ravidorr/murphys-laws.git",
    "directory": "mcp"
  },
  "homepage": "https://murphys-laws.com/developers",
  "license": "CC0-1.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3"
  }
}

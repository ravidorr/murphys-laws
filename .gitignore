# Platform-specific build outputs
backend/dist/
web/dist/

# Generated at build time by build:openapi
web/public/openapi.json

# On-demand DTCG exports of DESIGN.md (for designers importing into Figma / Style Dictionary).
# Regenerate with `npm run design:export`.
web/.design-exports/

# Generated iOS design-token outputs from shared/design-tokens/export-ios-tokens.ts.
# Regenerated by ios/generate-xcode-project.sh before xcodegen, and by
# `npm run design:export:ios` on demand. Not tracked because
# they're a deterministic function of shared/DESIGN.md and re-deriving on
# every build keeps PR diffs sane.
ios/MurphysLaws/Assets.xcassets/DS/
ios/MurphysLaws/DesignSystem/

# Generated Android design-token outputs from shared/design-tokens/export-android-tokens.ts.
# Regenerated by the `exportDesignTokens` Gradle task (preBuild dependency),
# and by `npm run design:export:android` on demand. Same
# rationale as the iOS outputs above.
android/app/src/main/java/com/murphyslaws/ui/theme/Tokens.kt
android/app/src/main/res/values/colors.xml
android/app/src/main/res/values/dimens.xml
android/app/src/main/res/values-night/colors.xml
